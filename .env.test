# --- Application -------------------------------------------------------------
# Environnement : local | development | test
NODE_ENV=test
APP_NAME=nestjs-enterprise-starter
APP_HOST=0.0.0.0
APP_PORT=3001
APP_GLOBAL_PREFIX=api
APP_VERSION=1
# Origines CORS autorisÃ©es, sÃ©parÃ©es par des virgules
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Base de donnÃ©es SQL Server ------------------------------------------------
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
# Mot de passe SQL Server (Ã©galement utilisÃ© par docker-compose)
DB_PASSWORD=LocalDev!Wi3LReKTd2K9
DB_DATABASE=nestjs_starter_test
DB_TEST_DATABASE=nestjs_starter_test
DB_ENCRYPT=true
# true en local : le certificat du conteneur est auto-signÃ©
DB_TRUST_SERVER_CERTIFICATE=true

# --- JWT -----------------------------------------------------------------------
# Secrets d'au moins 32 caractÃ¨res. GÃ©nÃ©rer par exemple avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=86499d3ca2367e9d9b460fa7719e546387708a653bea0c8cc28caa42f4a341cfec243d76b56488208a4498d5d31f1a01
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=2a6f184c217afb05c43442334253e6783ae47d998f7cf9f172196a11a956dfb202d28fb34b1f6cb521552425df1751a8
JWT_REFRESH_EXPIRATION=7d

# --- Cookie de refresh token -----------------------------------------------------
REFRESH_COOKIE_NAME=refresh_token
# false en local (pas de HTTPS), true dÃ¨s qu'un HTTPS est disponible
REFRESH_COOKIE_SECURE=false
# lax | strict | none ("none" impose Secure=true)
REFRESH_COOKIE_SAME_SITE=lax
# Laisser vide en local
REFRESH_COOKIE_DOMAIN=

# --- ObservabilitÃ© et fonctionnalitÃ©s ---------------------------------------------
# fatal | error | warn | info | debug | trace
LOG_LEVEL=warn
SWAGGER_ENABLED=false
METRICS_ENABLED=false
SCHEDULER_ENABLED=false
# Endpoints de dÃ©monstration technique (mail, fichiers, PDF)
TECHNICAL_DEMO_ENDPOINTS_ENABLED=true

# --- E-mails ------------------------------------------------------------------------
# development : journalise sans envoyer | smtp : envoi rÃ©el
MAIL_DRIVER=development
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com

# --- Stockage de fichiers --------------------------------------------------------------
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
# Taille maximale en octets (10 Mo)
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain
